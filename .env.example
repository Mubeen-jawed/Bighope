# ── Sanity CMS ────────────────────────────────────────────
# From your Sanity project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Write token (Sanity → API → Tokens, "Editor" role).
# ONLY needed by scripts/migrate-to-sanity.ts. Do NOT expose publicly.
SANITY_API_WRITE_TOKEN=your_write_token

# Any random string. Must match the Secret you set on the Sanity webhook.
SANITY_REVALIDATE_SECRET=choose_a_long_random_string

# ── Gmail SMTP (contact / quote forms) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
RECEIVER_EMAIL=your_email@gmail.com
